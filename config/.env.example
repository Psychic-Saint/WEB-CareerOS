# =============================================================
# Eddie's Job Pipeline v5 — copy to .env and fill in
# NEVER commit .env to git — it holds private data
# =============================================================

# --- AI engines (for scoring + cover letters) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
DEFAULT_AI_ENGINE=claude

# --- Your personal info (pre-fills application forms) ---
APPLICANT_FULL_NAME=Eddie Bila
APPLICANT_FIRST_NAME=Eddie
APPLICANT_LAST_NAME=Bila
APPLICANT_EMAIL=eddiebila10@gmail.com
APPLICANT_PHONE=+27 XX XXX XXXX
APPLICANT_LINKEDIN=https://www.linkedin.com/in/your-profile
APPLICANT_ORG=Your Most Recent Employer

# SA ID — used by Simplify.hr and SA ATS forms. Keep in .env only.
APPLICANT_ID_NUMBER=

# Full path to your CV (PDF preferred)
CV_PATH=C:\Users\Teddy\Downloads\Personal (Eddie)\Eddie_Bila_CV_2026.pdf

# --- Auto-apply settings ---
# true = system submits forms automatically on safe platforms
# false = everything escalated to you for manual review
AUTO_SUBMIT_ENABLED=true

# Run browser invisible (true) or visible so you can watch (false)
HEADLESS=true

# Generate a tailored cover letter per job before submitting
AUTO_COVER_LETTER=true

# Maximum applications per daily run (safety limit)
DAILY_AUTO_APPLY_LIMIT=15

# Only auto-apply to jobs scoring at or above this threshold
AUTO_APPLY_MIN_SCORE=60

# Minimum score to even keep a job in the queue (lower = broader)
MIN_FIT_SCORE=55

# What time the daily run fires (24h, Africa/Johannesburg timezone)
DAILY_RUN_TIME=07:00
